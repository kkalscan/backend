# See docs/github-secrets.md
PORT=8080
DATABASE_URL=jdbc:sqlite:./data/kkalscan.db

JWT_SECRET=change-me-min-32-chars-in-production
JWT_ISSUER=kkalscan

# stub = fake dishes (tests); openrouter = real vision
VISION_PROVIDER=stub
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
VISION_MONTHLY_BUDGET_RUB=5000

SMTP_HOST=mail.antonbutov.com
SMTP_PORT=465
SMTP_USER=mail@antonbutov.com
SMTP_PASSWORD=
SMTP_FROM=mail@antonbutov.com
BUG_REPORT_NOTIFY_TO=mail@antonbutov.com
SMTP_USE_TLS=true

TOCHKA_MERCHANT_ID=
TOCHKA_SECRET_KEY=
TOCHKA_ACCESS_TOKEN=
# Optional: only if Tochka returns several customers (otherwise fetched via API)
TOCHKA_CUSTOMER_CODE=
TOCHKA_WEBHOOK_SECRET=
PUBLIC_BASE_URL=http://91.207.75.72:8080
# Local free Pro without Tochka: true. Prod deploy defaults to false via generate-env.sh.
FREE_PRO_ACTIVATION=false

VK_APP_ID=
VK_SERVICE_TOKEN=
